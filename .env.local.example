# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — for Gmail integration (not Supabase Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth — for LinkedIn Share connection
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Adzuna Job Search API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# App URL (used for OAuth callbacks and sharing)
NEXT_PUBLIC_APP_URL=https://job-application-platform-lake.vercel.app

# Cron job auth token (also used for E2E login endpoint)
CRON_SECRET=

# E2E test auth secret (falls back to CRON_SECRET if unset)
E2E_SECRET=

# E2E test user email
TEST_USER_EMAIL=
